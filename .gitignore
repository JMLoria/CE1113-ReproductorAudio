*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# debug information files
*.dwo

# ==========================================
# Intel Quartus & Platform Designer Outputs
# ==========================================
# Carpetas de base de datos de síntesis e incremental
db/
incremental_db/
/hw/db/
/hw/incremental_db/

# Reportes y logs de compilación
*.rpt
*.summary
*.smsg
*.txt
*.done
*.jdi
*.pin
*.qws

# Archivos de bitstream finales (se generan localmente)
*.sof
*.pof
*.ttf

# Archivos temporales de Platform Designer
.qsys_edit/
*.modules
*.csv
*.spd

# ==========================================
# Nios II Software Build Tools (Eclipse / BSP)
# ==========================================
# Archivos de configuración del Workspace de Eclipse
.metadata/
RemoteSystemsTempFiles/
.recommenders/

# Archivos temporales y de configuración local del proyecto
/sw/nios/app/obj/
/sw/nios/app_bsp/obj/
/sw/nios/app_bsp/generated.sh
/sw/nios/app_bsp/Makefile
/sw/nios/app_bsp/settings.bsp

# Reportes y logs del enlazador/compilador de software
*.bak
*.log

# ==========================================
# Preloader / U-Boot (generado por SoC EDS: miles de archivos, regenerable)
# ==========================================
/sw/preloader/

# ==========================================
# Apps bare-metal del HPS (binarios generados) y script de arranque compilado
# ==========================================
/sw/*.bin
/sw/*.srec
u-boot.scr

# Mantener en el repo los fuentes de scripts aunque *.txt esté ignorado arriba
!hw/scripts/boot.txt

# ==========================================
# Canciones (binarios grandes; van a la SD, NO al repo)
# ==========================================
/songs/
*.mp4
*.wav
*.WAV
*.mp3
*.flac